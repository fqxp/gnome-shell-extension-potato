<?xml version="1.0" encoding="UTF-8"?>
<schemalist gettext-domain="potato">
  <schema id="org.gnome.shell.extensions.potato"
          path="/org/gnome/shell/extensions/potato/">

    <key name="work-duration" type="u">
      <default>25</default>
      <summary>Work duration in minutes</summary>
    </key>

    <key name="rest-duration" type="u">
      <default>5</default>
      <summary>Rest duration in minutes</summary>
    </key>

    <key name="disable-skip" type="b">
      <default>false</default>
      <summary>Disable the Skip button</summary>
    </key>

  </schema>
</schemalist>
